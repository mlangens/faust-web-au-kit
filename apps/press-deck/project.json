      },
      {
        "label": "Range",
        "value": 18
      },
      {
        "label": "Detector Focus",
        "value": 0
      }
    ],
    "nativeTargets": [
      "c",
      "cpp",
      "wasm"
    ],
    "exportOnlyTargets": [
      "cmajor",
      "rust"
    ]
  }
}
