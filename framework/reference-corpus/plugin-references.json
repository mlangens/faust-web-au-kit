  "displayName": "FWAK Reference Plugin Corpus",
  "description": "Framework-level observations from sample suites and outside plugin manuals used to extract reusable DSP, UI, and sonic-validation primitives.",
  "methodology": {
    "frameworkGoal": "Use reference plugins as research specimens for primitive extraction, not as product identities to preserve.",
    "sampleSuitePolicy": "Sample suites are disposable validation packs. Northline is a proving suite and may be replaced as the primitive library matures.",
    "cloneDistance": "Extract function, architecture, interaction grammar, and testable behavior while avoiding brand-specific visual identity or proprietary implementation details.",
    "extractionFlow": [
      "Observe a reference product or sample suite.",
      "Extract feature signals into primitive IDs.",
      "Promote primitives through maturity stages.",
      "Bind primitives to reusable surfaces and sonic probes.",
      "Validate with sample suites and staged plugin output."
    ]
  },
