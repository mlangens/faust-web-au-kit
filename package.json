{
  "name": "faust-web-au-kit",
  "version": "0.1.3",
  "private": false,
  "description": "A target-agnostic Faust framework proof of concept with an oversampled AU limiter and cross-target benchmarks.",
  "type": "module",
  "scripts": {
    "export": "node ./tools/export-targets.mjs",
    "export:synth": "node ./tools/export-targets.mjs --project projects/pulse_pad.json",
    "benchmark": "node ./tools/run-benchmarks.mjs",
    "preview": "node ./tools/preview-server.mjs",
    "build:au": "./scripts/build-au.sh",
    "build:native": "./scripts/build-native.sh",
    "doctor:au": "./scripts/doctor-au.sh",
    "install:local": "./scripts/install-local.sh",
    "package:installer": "./scripts/package-installer.sh",
    "validate:au": "./scripts/validate-au.sh"
  }
}
