{
  "$schemaVersion": 1,
  "id": "northline-core",
  "displayName": "Studio Workbench Core",
  "description": "Shared metadata for analyzer-led, meter-rich, modulation-capable audio plug-ins built from a common shell.",
  "catalog": {
    "suite": "northline-suite"
  },
  "presentation": {
    "style": "studio-neutral-industrial",
    "cloneDistance": "feature-first"
  },
  "shell": {
    "eyebrow": "Northline Prototype"
  },
  "positioning": {
    "intent": "Preserve the functional clarity and composable surface model of the research set while steering the future suite toward a more generic studio-industrial presentation.",
    "visualDirection": "studio-neutral-industrial",
    "designRules": [
      "Use rounded-rectangle buttons, restrained dials, and neutral panels instead of direct brand-signature control silhouettes.",
      "Keep the shell consistent across products and let the central editor surface communicate product identity.",
      "Favor muted metal, parchment, and glassy accent combinations over glow-heavy, clone-faithful color blocking.",
      "Treat animations as informative instrumentation, not decorative theater."
    ],
    "antiGoals": [
      "Do not copy product-faithful button chrome, exact halo treatments, or signature panel gradients.",
      "Do not depend on a single accent color family for the entire suite.",
      "Do not encode product layout assumptions into the shell when they belong to a reusable surface preset."
    ]
  },
  "visualLanguage": {
    "shapeTokens": {
      "panelRadius": 16,
      "controlRadius": 12,
      "microRadius": 8,
      "dialRingWidth": 6,
      "dividerWeight": 1,
      "meterWidth": 10,
      "focusHaloBlur": 14
    },
    "palette": {
      "canvas": "#171a1e",
      "panel": "#20252b",
      "panelElevated": "#272d35",
      "panelInset": "#14171b",
      "line": "#39414c",
      "lineSoft": "#2d333c",
      "textStrong": "#ebe6dc",
      "textMuted": "#98a2ad",
      "textDim": "#69727d",
      "focus": "#d9a64a",
      "info": "#63b7c8",
      "positive": "#72bf78",
      "warning": "#d38a54",
      "danger": "#dc6b63"
    },
    "accentPalettes": {
      "amber-slate": {
        "primary": "#d7a24e",
        "secondary": "#7cc3c6",
        "surfaceTint": "#2b2a25"
      },
      "teal-sand": {
        "primary": "#69b6b7",
        "secondary": "#d4b17a",
        "surfaceTint": "#242a29"
      },
      "copper-sky": {
        "primary": "#cf8759",
        "secondary": "#79b4d1",
        "surfaceTint": "#2b2522"
      },
      "sea-ember": {
        "primary": "#68b1c5",
        "secondary": "#d98a5d",
        "surfaceTint": "#22292a"
      },
      "moss-brass": {
        "primary": "#8ea85f",
        "secondary": "#caa356",
        "surfaceTint": "#252922"
      },
      "sand-mint": {
        "primary": "#d6c198",
        "secondary": "#80bda3",
        "surfaceTint": "#2b2924"
      }
    },
    "typography": {
      "primaryFamily": "Satoshi, General Sans, Avenir Next, sans-serif",
      "secondaryFamily": "IBM Plex Sans Condensed, sans-serif",
      "caseStyle": "sentence-case labels with uppercase micro-labels only for meters and transport-sized affordances",
      "figureStyle": "tabular values for meters, curves, and typed entry"
    },
    "motion": {
      "easing": "fast-out-slow-in",
      "hoverDurationMs": 90,
      "popoverDurationMs": 120,
      "meterSmoothing": "restrained",
      "animationBias": "instrument-first"
    },
    "chrome": {
      "buttonStyle": "capsule",
      "toggleStyle": "segmented-inset",
      "dialStyle": "matte-pointer-arc",
      "meterStyle": "thin-trough",
      "gridStyle": "soft-crosshair",
      "surfaceStyle": "matte-workbench"
    }
  },
  "sharedPrimitives": {
    "shell": [
      "preset-header",
      "ab-compare",
      "undo-redo",
      "help-entry",
      "resize-handle",
      "full-screen-toggle",
      "status-strip"
    ],
    "controls": [
      "dial",
      "mini-dial",
      "segmented-toggle",
      "capsule-button",
      "vertical-slider",
      "range-slider",
      "band-handle",
      "slot-chip",
      "xy-pad",
      "virtual-keyboard"
    ],
    "surfaces": [
      "graph-canvas",
      "history-trace",
      "multiband-editor",
      "meter-stack",
      "routing-matrix",
      "module-rack",
      "delay-timeline",
      "keyboard-strip"
    ],
    "overlays": [
      "popover-panel",
      "value-bubble",
      "selection-rectangle",
      "audition-overlay",
      "modulation-target-highlight",
      "instance-list"
    ]
  },
  "interactionGrammar": {
    "knobs": [
      "Vertical drag is the default gesture.",
      "Shift enables fine adjustment.",
      "Mouse wheel increments the current value when available.",
      "Double-click opens typed entry when a renderer supports it.",
      "Reset should prefer modifier-click over dedicated chrome where possible."
    ],
    "canvases": [
      "Primary displays should accept direct manipulation for creation, drag, resize, and multi-selection.",
      "Rectangle selection is preferred for band, node, and region surfaces.",
      "Alt-modified gestures can toggle bypass or linked movement, but visual hints should stay generic rather than brand-mimetic.",
      "Popovers should anchor near the selected entity and never obscure the full editor unnecessarily."
    ],
    "popovers": [
      "Hover may reveal read-only context; click makes advanced panels sticky.",
      "Output or options popovers should open from the footer or meter edge, not from hidden hot zones alone.",
      "Transient overlays should fade quickly and avoid theatrical scale animations."
    ],
    "modulation": [
      "Drag sources to targets to create routings.",
      "Source and target highlighting should prioritize contrast over glow volume.",
      "Slot editors should be compact cards with clear invert, amount, bypass, and remove actions.",
      "The modulation language should be identical across synth, filter, delay, and saturation products."
    ]
  },
