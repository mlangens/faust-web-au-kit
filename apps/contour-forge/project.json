{
  "name": "contour-forge",
  "version": "0.2.0",
  "owner": "mlangens",
  "companyName": "Max Langensiepen",
  "companyTag": "Mlng",
  "productName": "Contour Forge",
  "artifactStem": "ContourForge",
  "bundleId": "io.github.mlangens.faust-web-au-kit.contour-forge",
  "description": "Routable filter with deeper motion sources, spread-aware stereo behavior, and a denser Northline modulation surface.",
  "license": "MIT",
  "plugin": {
    "kind": "effect",
    "inputs": 2,
    "outputs": 2,
    "midiInput": false,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "auv2",
      "clap",
      "vst3",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 1
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "ContourForgeDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "routable-filter",
    "catalog": {
      "productId": "contour-forge",
      "prototypeRole": "creative-fidelity-pass"
    },
    "shell": {
      "hero": {
        "status": "Routable filter fidelity pass with deeper motion sources, spread-aware stereo shaping, and neutral Northline studio chrome."
      },
      "sections": {
        "controls": {
          "title": "Filter Surface",
          "description": "Contour Forge now leans into reusable motion vocabulary: source selection, spread, bias, routing, and stereo-linked filter behavior."
        },
        "meters": {
          "title": "Motion Preview",
          "description": "The surface now separates motion depth, drive heat, stereo spread, and output so the preview reads more like a finished creative processor."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Mode": [
          "Low Pass",
          "Band Pass",
          "Notch",
          "High Pass"
        ],
        "Style": [
          "Neutral",
          "Warm",
          "Bite",
          "Wide"
        ],
        "Motion Source": [
          "Env",
          "LFO",
          "Hybrid"
        ],
        "Routing": [
          "Stereo",
          "Mid/Side",
          "Mono"
        ]
      }
    },
    "statusText": "Routable filter with selectable motion source, stereo spread shaping, drive staging, envelope/LFO bias, routing control, mix, and output trim.",
    "controlOrder": [
      "Mode",
      "Style",
      "Motion Source",
      "Cutoff",
      "Resonance",
      "Drive",
      "Filter Spread",
      "Env Amount",
      "Env Speed",
      "Motion Bias",
      "LFO Rate",
      "LFO Depth",
      "Stereo Link",
      "Routing",
      "Mix",
      "Output Trim",
      "Bypass"
    ],
    "meters": [
      {
        "id": "inputPeak",
        "label": "Input Peak",
        "max": 78,
        "mode": "peak"
      },
      {
        "id": "motionDepth",
        "label": "Motion Depth",
        "max": 100,
        "mode": "peak",
        "unit": "%"
      },
      {
        "id": "driveHeat",
        "label": "Drive Heat",
        "max": 78,
        "mode": "peak",
        "unit": "dB"
      },
      {
        "id": "stereoSpread",
        "label": "Stereo Spread",
        "max": 100,
        "mode": "peak",
        "unit": "%"
      },
      {
        "id": "outputPeak",
        "label": "Output Peak",
        "max": 78,
        "mode": "peak",
        "unit": "dB"
      }
    ]
  },
  "au": {
    "type": "aufx",
    "subtype": "CtFg",
    "manufacturer": "Mlng",
    "tags": [
      "Filter",
