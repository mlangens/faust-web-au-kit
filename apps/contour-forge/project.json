              "control": "Routing",
              "matchValue": 0,
              "cells": [
                {
                  "row": "stereo",
                  "column": "input"
                },
                {
                  "row": "stereo",
                  "column": "motion"
                },
                {
                  "row": "stereo",
                  "column": "output"
                }
              ],
              "readouts": [
                "Routing",
                "Stereo Link",
                "Mix"
              ]
            },
            {
              "id": "mid-side-route",
