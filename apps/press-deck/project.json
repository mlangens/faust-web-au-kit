{
  "name": "press-deck",
  "version": "0.2.0",
  "owner": "mlangens",
  "companyName": "Max Langensiepen",
  "companyTag": "Mlng",
  "productName": "Press Deck",
  "artifactStem": "PressDeck",
  "bundleId": "io.github.mlangens.faust-web-au-kit.press-deck",
  "description": "Character compressor with richer detector options, audition paths, and a denser dynamics surface built on the shared Northline family.",
  "license": "MIT",
  "plugin": {
    "kind": "effect",
    "inputs": 2,
    "outputs": 2,
    "midiInput": false,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "auv2",
      "clap",
      "vst3",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 2
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "PressDeckDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "character-compressor",
    "catalog": {
      "productId": "press-deck",
      "prototypeRole": "fidelity-wave-press-deck"
    },
    "shell": {
      "hero": {
        "status": "Character compressor fidelity pass with richer detector routing, denser timing control, and neutral Northline studio chrome."
      },
      "sections": {
        "controls": {
          "title": "Dynamics Surface",
          "description": "Press Deck now centers on mode-driven compression, detector shaping, stereo linking, parallel blend, and output management."
        },
        "meters": {
          "title": "Response Preview",
          "description": "The surface contract now tracks input, detector drive, gain reduction, and output so the dynamics lane reads more like a finished tool."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Mode": [
          "Punch",
          "Glue",
          "Lift",
          "Crush"
        ],
        "Character": [
          "Clean",
          "Warm",
          "Bold"
        ],
        "Detector Mode": [
          "Peak",
          "Blend",
          "Average"
        ],
        "Detector Focus": [
          "Full",
          "Body",
          "Air"
        ],
        "Audition": [
          "Program",
          "Delta",
          "Detector"
        ]
      }
    },
    "preview": {
      "controls": {
        "layout": "sectioned",
        "sections": [
          {
            "id": "compression-voice",
            "title": "Compression Voice",
            "description": "Keep compressor mode, detector flavor, and audition paths in one shared segmented strip.",
            "kind": "segmented-strip",
            "items": [
              {
                "control": "Mode"
              },
              {
                "control": "Character"
              },
              {
                "control": "Detector Mode"
              },
              {
                "control": "Detector Focus"
              },
              {
                "control": "Audition"
              }
            ]
          },
          {
            "id": "compression-staging",
            "title": "Compression Staging",
            "description": "Core input, threshold, ratio, knee, range, blend, and output moves now sit in a shared fader bank.",
            "kind": "fader-bank",
            "columns": 7,
            "items": [
              {
                "control": "Input Gain"
              },
              {
                "control": "Threshold"
              },
              {
                "control": "Ratio"
              },
              {
                "control": "Knee"
              },
              {
                "control": "Range",
                "surfaceOnly": true
              },
              {
                "control": "Mix",
                "surfaceOnly": true
              },
              {
                "control": "Output",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "detector-response",
            "title": "Detector Response",
            "description": "Use the shared dial grid for timing, detector filtering, and stereo-link behavior.",
            "kind": "dial-grid",
            "columns": 5,
            "items": [
              {
                "control": "Attack"
              },
              {
                "control": "Release"
              },
              {
                "control": "Detector HP",
                "surfaceOnly": true
              },
              {
                "control": "Detector Tilt",
                "surfaceOnly": true
              },
              {
                "control": "Stereo Link",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "output-utilities",
            "title": "Output Utilities",
            "description": "Keep global utility switches together in a compact toggle bank.",
            "kind": "toggle-bank",
            "items": [
              {
                "control": "Auto Trim",
                "surfaceOnly": true
              },
              {
                "control": "Bypass"
              }
            ]
          }
        ],
        "supplementalTitle": "Additional Controls",
        "supplementalDescription": "Any compressor parameters not yet mapped into the grouped layout stay available here while the preview evolves."
      },
