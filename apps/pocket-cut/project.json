  "productName": "Pocket Cut",
  "artifactStem": "PocketCut",
  "bundleId": "io.github.mlangens.faust-web-au-kit.pocket-cut",
  "description": "Mini filter utility scaffold with shared Northline family metadata, envelope-follow motion, drive, mix, and bypass.",
