{
  "name": "room-bloom",
  "version": "0.2.0",
  "owner": "mlangens",
  "companyName": "Max Langensiepen",
  "companyTag": "Mlng",
  "productName": "Room Bloom",
  "artifactStem": "RoomBloom",
  "bundleId": "io.github.mlangens.faust-web-au-kit.room-bloom",
  "description": "Stereo ambience processor with layered room voicing, tail shaping, ducking, and freeze-aware bloom controls.",
  "license": "MIT",
  "plugin": {
    "kind": "effect",
    "inputs": 2,
    "outputs": 2,
    "midiInput": false,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "auv2",
      "clap",
      "vst3",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 1
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "RoomBloomDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "space-reverb",
    "catalog": {
      "productId": "room-bloom",
      "prototypeRole": "fidelity-wave-pass-1"
    },
    "overrides": {
      "surfacePresetIds": [
        "reverb-space",
        "meter-stack",
        "output-popover"
      ],
      "layoutProfile": "macro-row-plus-canvas"
    },
    "shell": {
      "hero": {
        "status": "Stereo ambience surface with layered room voicing, bloom shaping, ducking, and freeze-aware tail control."
      },
      "sections": {
        "controls": {
          "title": "Ambience Surface",
          "description": "Room Bloom now exposes a richer reusable reverb vocabulary with room selection, character voicing, width, tone shaping, and duck timing controls."
        },
        "meters": {
          "title": "Tail Response",
          "description": "The meter contract now separates early activity, late tail energy, stereo spread, ducking, and output level for more informative preview behavior."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Space": [
          "Room",
          "Chamber",
          "Hall",
          "Vast"
        ],
        "Character": [
          "Clear",
          "Warm",
          "Dense",
          "Air"
        ]
      }
    },
    "preview": {
      "controls": {
        "layout": "sectioned",
        "sections": [
          {
            "id": "scene-voicing",
            "title": "Scene + Voicing",
            "description": "Room selection and character stay up front so Room Bloom feels editor led before the deeper tail shaping starts.",
            "kind": "segmented-strip",
            "items": [
              {
                "control": "Space"
              },
              {
                "control": "Character"
              }
            ]
          },
          {
            "id": "entry-tail",
            "title": "Entry + Tail",
            "description": "Core bloom timing gathers size, pre-delay, decay, and bloom into one shared shaping cluster.",
            "kind": "dial-grid",
            "columns": 4,
            "items": [
              {
                "control": "Size",
                "surfaceOnly": true
              },
              {
                "control": "Pre-Delay",
                "surfaceOnly": true
              },
              {
                "control": "Decay",
                "surfaceOnly": true
              },
              {
                "control": "Bloom",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "field-shape",
            "title": "Field Shape",
            "description": "Stereo spread and tone filtering sit together so the ambience field reads like one editorial space panel.",
            "kind": "dial-grid",
            "columns": 4,
            "items": [
              {
                "control": "Width",
                "surfaceOnly": true
              },
              {
                "control": "Diffusion",
                "surfaceOnly": true
              },
              {
                "control": "Low Cut",
                "surfaceOnly": true
              },
              {
                "control": "High Cut",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "duck-mix",
            "title": "Duck + Output",
            "description": "Ducking depth, release, wet balance, and final trim stay in a compact strip instead of a flat utility row.",
            "kind": "fader-bank",
            "columns": 4,
            "items": [
              {
                "control": "Ducking",
                "surfaceOnly": true
              },
              {
                "control": "Duck Release",
                "surfaceOnly": true
              },
              {
                "control": "Mix",
                "surfaceOnly": true
              },
              {
                "control": "Output",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "tail-utility",
            "title": "Tail Utility",
            "description": "Freeze and bypass stay together as the small utility bank for the reverb footer.",
            "kind": "toggle-bank",
            "items": [
              {
                "control": "Freeze",
                "surfaceOnly": true
              },
              {
                "control": "Bypass"
              }
            ]
          }
        ],
        "supplementalTitle": "Supplemental Room Controls",
        "supplementalDescription": "Any additional ambience helpers stay available here until the Room Bloom editor layout expands again."
      },
      "surfaces": {
        "reverb-space": {
          "title": "Reverb space",
          "description": "A shared macro canvas maps scene, entry, tail, spread, and tone movement without needing a room-specific renderer.",
          "selection": "tail-core",
          "focusBadges": [
            {
              "label": "Mix",
              "control": "Mix",
              "tone": "accent"
            },
            {
              "label": "Ducking",
              "control": "Ducking",
              "tone": "warning"
            },
            {
              "label": "Freeze",
              "control": "Freeze",
              "tone": "muted"
            }
          ],
          "nodes": [
            {
              "id": "scene-node",
              "label": "Scene",
              "accent": "info",
              "xControl": "Space",
              "xMin": 0,
              "xMax": 3,
              "yControl": "Character",
              "yMin": 0,
              "yMax": 3,
              "controls": [
                "Space",
                "Character"
              ],
              "readouts": [
                {
                  "label": "Space",
                  "control": "Space"
                },
                {
                  "label": "Character",
                  "control": "Character"
                }
              ]
            },
            {
              "id": "entry-node",
              "label": "Entry",
              "accent": "warning",
              "xControl": "Pre-Delay",
              "xMin": 0,
              "xMax": 180,
              "yControl": "Size",
              "yMin": 0,
              "yMax": 100,
              "meterId": "earlyEnergy",
              "readouts": [
                {
                  "label": "Pre-Delay",
                  "control": "Pre-Delay"
                },
                {
                  "label": "Size",
                  "control": "Size"
                }
              ]
            },
            {
              "id": "tail-core",
              "label": "Tail",
              "accent": "positive",
              "xControl": "Decay",
              "xMin": 0.3,
              "xMax": 12,
              "yControl": "Bloom",
              "yMin": 0,
              "yMax": 100,
              "meterId": "tailEnergy",
              "readouts": [
                {
                  "label": "Decay",
                  "control": "Decay"
                },
                {
                  "label": "Bloom",
                  "control": "Bloom"
                }
              ]
            },
            {
              "id": "spread-node",
              "label": "Field",
              "accent": "accent",
              "xControl": "Width",
              "xMin": 0,
              "xMax": 100,
              "yControl": "Diffusion",
              "yMin": 0,
              "yMax": 100,
              "meterId": "stereoSpread",
              "readouts": [
                {
                  "label": "Width",
                  "control": "Width"
                },
                {
                  "label": "Diffusion",
                  "control": "Diffusion"
                }
              ]
            },
            {
              "id": "tone-window",
              "label": "Tone",
              "accent": "info",
              "xControl": "High Cut",
              "xMin": 1200,
              "xMax": 18000,
              "yControl": "Low Cut",
              "yMin": 20,
              "yMax": 1200,
              "frequencyScale": "log",
              "control": "Ducking",
              "readouts": [
                {
                  "label": "Low Cut",
                  "control": "Low Cut"
                },
                {
                  "label": "High Cut",
                  "control": "High Cut"
                }
              ]
            }
          ],
          "links": [
            {
              "from": "scene-node",
              "to": "entry-node",
              "tone": "warning"
            },
            {
              "from": "entry-node",
              "to": "tail-core",
              "tone": "accent"
            },
            {
              "from": "tail-core",
              "to": "spread-node",
              "tone": "positive"
            },
            {
              "from": "tail-core",
              "to": "tone-window",
              "tone": "info"
            }
          ]
        },
        "output-popover": {
          "title": "Output and ducking",
          "description": "Shared footer utilities cover duck timing, wet balance, freeze, and final output trim.",
          "items": [
            {
              "label": "Ducking",
              "control": "Ducking"
            },
            {
              "label": "Duck Release",
              "control": "Duck Release"
            },
            {
              "label": "Mix",
              "control": "Mix"
            },
            {
              "label": "Output",
              "control": "Output"
            },
            {
              "label": "Freeze",
              "control": "Freeze"
            }
          ]
        }
      }
    },
    "statusText": "Layered ambience processor with space/character selection, bloom shaping, stereo width, frequency shaping, duck timing, and freeze-aware tail control.",
    "controlOrder": [
      "Space",
      "Character",
      "Size",
      "Pre-Delay",
      "Decay",
      "Diffusion",
      "Width",
      "Bloom",
      "Low Cut",
      "High Cut",
      "Ducking",
      "Duck Release",
      "Mix",
      "Output",
      "Freeze",
      "Bypass"
    ],
    "meters": [
      {
        "id": "inputPeak",
        "label": "Input Peak",
        "max": 78,
        "mode": "peak",
        "unit": "dB",
        "description": "Pre-effect stereo input level."
      },
      {
        "id": "earlyEnergy",
        "label": "Early Energy",
        "max": 78,
        "mode": "peak",
        "unit": "dB",
        "description": "Energy in the short early-reflection cluster."
      },
      {
        "id": "tailEnergy",
        "label": "Tail Energy",
        "max": 78,
        "mode": "peak",
        "unit": "dB",
        "description": "Sustained late bloom level after the tail tanks."
      },
      {
        "id": "stereoSpread",
        "label": "Stereo Spread",
        "max": 100,
        "mode": "peak",
        "unit": "%",
        "description": "Relative wet-side energy after width shaping."
      },
      {
        "id": "duckReduction",
        "label": "Duck Reduction",
        "max": 24,
        "mode": "gr",
        "unit": "dB",
        "description": "Approximate attenuation applied to the wet path by the ducking detector."
      },
      {
        "id": "outputPeak",
        "label": "Output Peak",
        "max": 78,
        "mode": "peak",
        "unit": "dB",
        "description": "Post-mix stereo output level."
      }
    ]
  },
  "au": {
    "type": "aufx",
    "subtype": "Rblm",
    "manufacturer": "Mlng",
    "tags": [
      "Effects",
      "Reverb"
    ]
  },
  "clap": {
