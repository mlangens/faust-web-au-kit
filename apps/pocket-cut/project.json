      "audio-effect",
      "analyzer",
      "mixing",
      "stereo",
      "utility"
    ]
  },
  "vst3": {
    "categories": [
      "Fx",
      "Filter",
      "Stereo"
    ],
    "componentTuid": [
      "Mlng",
      "Comp",
