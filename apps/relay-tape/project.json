          "focusBadges": [
            {
              "label": "Mode",
              "control": "Mode",
              "tone": "accent"
            },
            {
              "label": "Routing",
              "control": "Routing",
              "tone": "muted"
            },
            {
              "label": "Freeze",
              "control": "Freeze",
              "tone": "muted"
