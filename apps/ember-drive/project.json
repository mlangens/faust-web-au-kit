  "artifactStem": "EmberDrive",
  "bundleId": "io.github.mlangens.faust-web-au-kit.ember-drive",
  "description": "Multiband saturation processor with style-selectable drive shaping, per-band tone and bias control, dynamic glue, stereo width, and output management.",
  "license": "MIT",
  "plugin": {
    "kind": "effect",
    "inputs": 2,
    "outputs": 2,
    "midiInput": false,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
