{
  "name": "contour-forge",
  "version": "0.2.0",
  "owner": "mlangens",
  "companyName": "Max Langensiepen",
  "companyTag": "Mlng",
  "productName": "Contour Forge",
  "artifactStem": "ContourForge",
  "bundleId": "io.github.mlangens.faust-web-au-kit.contour-forge",
  "description": "Routable filter with deeper motion sources, spread-aware stereo behavior, and a denser Northline modulation surface.",
  "license": "MIT",
  "plugin": {
    "kind": "effect",
    "inputs": 2,
    "outputs": 2,
    "midiInput": false,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "auv2",
      "clap",
      "vst3",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 1
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "ContourForgeDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "routable-filter",
    "catalog": {
      "productId": "contour-forge",
      "prototypeRole": "creative-fidelity-pass"
    },
    "shell": {
      "hero": {
        "status": "Routable filter fidelity pass with deeper motion sources, spread-aware stereo shaping, and neutral Northline studio chrome."
      },
      "sections": {
        "controls": {
          "title": "Filter Surface",
          "description": "Contour Forge now leans into reusable motion vocabulary: source selection, spread, bias, routing, and stereo-linked filter behavior."
        },
        "meters": {
          "title": "Motion Preview",
          "description": "The surface now separates motion depth, drive heat, stereo spread, and output so the preview reads more like a finished creative processor."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Mode": [
          "Low Pass",
          "Band Pass",
          "Notch",
          "High Pass"
        ],
        "Style": [
          "Neutral",
          "Warm",
          "Bite",
          "Wide"
        ],
        "Motion Source": [
          "Env",
          "LFO",
          "Hybrid"
        ],
        "Routing": [
          "Stereo",
          "Mid/Side",
          "Mono"
        ]
      }
    },
    "preview": {
      "controls": {
        "layout": "sectioned",
        "sections": [
          {
            "id": "topology-strip",
            "title": "Topology",
            "description": "Shared segments keep filter mode, voicing, motion source, and routing aligned before the deeper motion widgets take over.",
            "kind": "segmented-strip",
            "items": [
              {
                "control": "Mode",
                "widget": "segment"
              },
              {
                "control": "Style",
                "widget": "segment"
              },
              {
                "control": "Motion Source",
                "widget": "segment"
              },
              {
                "control": "Routing",
                "widget": "segment"
              }
            ]
          },
          {
            "id": "filter-core",
            "title": "Filter Core",
            "description": "Cutoff, resonance, and drive now read as one shared filter block instead of a flat control row.",
            "kind": "dial-grid",
            "columns": 3,
            "items": [
              {
                "control": "Cutoff",
                "widget": "dial",
                "surfaceOnly": true
              },
              {
                "control": "Resonance",
                "widget": "dial",
                "surfaceOnly": true
              },
              {
                "control": "Drive",
                "widget": "dial"
              }
            ]
          },
          {
            "id": "motion-grid",
            "title": "Motion Grid",
            "description": "Envelope and LFO widgets now share one motion bank with bias control.",
            "kind": "dial-grid",
            "columns": 3,
            "items": [
              {
                "control": "Env Amount",
                "widget": "dial",
                "surfaceOnly": true
              },
              {
                "control": "Env Speed",
                "widget": "dial",
                "surfaceOnly": true
              },
              {
                "control": "LFO Rate",
                "widget": "dial",
                "surfaceOnly": true
              },
              {
                "control": "LFO Depth",
                "widget": "dial",
                "surfaceOnly": true
              },
              {
                "control": "Motion Bias",
                "widget": "dial",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "field-stage",
            "title": "Field Stage",
            "description": "Spread, mix, and output trim move into a shared bus-level cluster.",
            "kind": "mixed-grid",
            "columns": 3,
            "items": [
              {
                "control": "Filter Spread",
                "widget": "slider",
                "surfaceOnly": true
              },
              {
                "control": "Mix",
                "widget": "fader",
                "surfaceOnly": true
              },
              {
                "control": "Output Trim",
                "widget": "fader",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "utility-toggles",
            "title": "Utilities",
            "description": "Shared toggles keep stereo linking and bypass out of the motion rows.",
            "kind": "toggle-bank",
            "items": [
              {
                "control": "Stereo Link",
                "widget": "toggle",
                "surfaceOnly": true
              },
              {
                "control": "Bypass",
                "widget": "toggle"
              }
            ]
          }
        ],
        "supplementalTitle": "Filter Readout",
        "supplementalDescription": "Contour Forge's preview now groups topology, filter tone, motion shaping, and bus utilities into shared widgets."
      },
      "surfaces": {
        "filter-canvas": {
          "title": "Motion filter canvas",
          "description": "The shared graph canvas now carries the cutoff core, envelope/LFO motion, and stereo spread routing for the creative filter lane.",
          "selection": "cutoff-core",
          "focusBadges": [
            {
              "label": "Mode",
              "control": "Mode",
              "tone": "accent"
            },
            {
              "label": "Style",
              "control": "Style",
              "tone": "muted"
            },
            {
              "label": "Motion Source",
              "control": "Motion Source",
              "tone": "muted"
            }
          ],
          "gridLabels": [
            "40",
            "120",
            "500",
            "2k",
            "8k",
            "18k"
          ],
          "bands": [
            {
              "id": "cutoff-core",
              "label": "Cutoff",
              "role": "bell",
              "accent": "info",
              "xControl": "Cutoff",
              "xMin": 40,
              "xMax": 18000,
              "frequencyScale": "log",
              "yControl": "Resonance",
              "yMin": 0,
              "yMax": 100,
              "qControl": "Filter Spread",
              "qMax": 100,
              "readouts": [
                "Cutoff",
                "Resonance",
                "Mode"
              ]
            },
            {
              "id": "env-band",
              "label": "Env",
              "role": "bell",
              "accent": "warning",
              "xControl": "Env Speed",
              "xMin": 0.005,
              "xMax": 0.5,
              "frequencyScale": "log",
              "yControl": "Env Amount",
              "yMin": 0,
              "yMax": 100,
              "readouts": [
                "Env Amount",
                "Env Speed",
                "Motion Source"
              ]
            },
            {
              "id": "lfo-band",
              "label": "LFO",
              "role": "bell",
              "accent": "positive",
              "xControl": "LFO Rate",
              "xMin": 0.03,
              "xMax": 6,
              "frequencyScale": "log",
              "yControl": "LFO Depth",
              "yMin": 0,
              "yMax": 100,
              "readouts": [
                "LFO Rate",
                "LFO Depth",
                "Motion Bias"
              ]
            },
            {
              "id": "spread-band",
              "label": "Spread",
              "role": "shelf",
              "accent": "accent",
              "x": 0.84,
              "yControl": "Filter Spread",
              "yMin": 0,
              "yMax": 100,
              "readouts": [
                "Routing",
                "Filter Spread",
                "Stereo Link"
              ]
            }
          ]
        },
        "routing-matrix": {
          "title": "Routing matrix",
          "description": "A shared routing matrix now makes the Stereo, Mid/Side, and Mono path choices visible without needing a custom app view.",
          "focusBadges": [
            {
              "label": "Routing",
              "control": "Routing",
              "tone": "accent"
            },
            {
              "label": "Motion Source",
              "control": "Motion Source",
              "tone": "muted"
            },
            {
              "label": "Stereo Link",
              "control": "Stereo Link",
              "tone": "muted"
            }
          ],
          "columns": [
            {
              "id": "input",
              "label": "Input"
            },
            {
              "id": "motion",
              "label": "Motion"
            },
            {
              "id": "output",
              "label": "Output"
            }
          ],
          "rows": [
            {
              "id": "stereo",
              "label": "Stereo"
            },
            {
              "id": "mid-side",
              "label": "Mid/Side"
            },
            {
              "id": "mono",
              "label": "Mono"
            }
          ],
          "routes": [
            {
              "id": "stereo-route",
