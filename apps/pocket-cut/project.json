{
  "name": "pocket-cut",
  "version": "0.1.0",
  "owner": "mlangens",
  "companyName": "Max Langensiepen",
  "companyTag": "Mlng",
  "productName": "Pocket Cut",
  "artifactStem": "PocketCut",
  "bundleId": "io.github.mlangens.faust-web-au-kit.pocket-cut",
  "description": "Mini filter utility scaffold with shared Northline family metadata, envelope-follow motion, drive, mix, and bypass.",
  "license": "MIT",
  "plugin": {
    "kind": "effect",
    "inputs": 2,
    "outputs": 2,
    "midiInput": false,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "auv2",
      "clap",
      "vst3",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 1
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "PocketCutDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "mini-filter",
    "catalog": {
      "productId": "pocket-cut",
      "prototypeRole": "parallel-wave-scaffold"
    },
    "overrides": {
      "surfacePresetIds": [
        "filter-canvas",
        "output-popover"
      ],
      "layoutProfile": "compact-surface"
    },
    "shell": {
      "hero": {
        "status": "Pocket Cut is a mini filter scaffold running on the shared family manifest with neutral studio chrome."
      },
      "sections": {
        "controls": {
          "title": "Filter Surface",
          "description": "Pocket Cut exposes a compact filter control set mapped through the shared Northline preview."
        },
        "meters": {
          "title": "Response Preview",
          "description": "Meter motion stays schematic for now, but the control surface and family metadata are real."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Mode": [
          "Low Pass",
          "Band Pass",
          "Notch",
          "High Pass"
        ]
      }
    },
    "preview": {
      "controls": {
        "layout": "sectioned",
        "sections": [
          {
            "id": "filter-mode",
            "title": "Filter Mode",
            "description": "Pocket Cut leads with one shared mode strip so the tiny utility lane still feels deliberate.",
            "kind": "segmented-strip",
            "items": [
              {
                "control": "Mode"
              }
            ]
          },
          {
            "id": "filter-core",
            "title": "Filter Core",
            "description": "Cutoff, resonance, and follow timing stay together as the main shaping cluster for the compact filter.",
            "kind": "dial-grid",
            "columns": 3,
            "items": [
              {
                "control": "Cutoff",
                "surfaceOnly": true
              },
              {
                "control": "Resonance",
                "surfaceOnly": true
              },
              {
                "control": "Envelope Follow",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "drive-output",
            "title": "Drive + Output",
            "description": "Drive, wet balance, and output trim sit in a compact strip instead of reading like loose utility sliders.",
            "kind": "fader-bank",
            "columns": 3,
            "items": [
              {
                "control": "Drive",
                "surfaceOnly": true
              },
              {
                "control": "Mix",
                "surfaceOnly": true
              },
              {
                "control": "Output",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "output-utility",
            "title": "Output Utility",
            "description": "Bypass stays isolated as the tiny output utility bank for the mini lane.",
            "kind": "toggle-bank",
            "items": [
              {
                "control": "Bypass"
              }
            ]
          }
        ],
        "supplementalTitle": "Supplemental Pocket Cut Controls",
        "supplementalDescription": "Any extra compact-filter helpers stay reachable here until Pocket Cut gets another reduced-manifest pass."
      },
      "surfaces": {
        "filter-canvas": {
          "title": "Compact filter canvas",
          "description": "A shared filter field keeps the mini lane focused on the main cutoff, envelope follow motion, and compact output shaping.",
          "selection": "cutoff-core",
          "focusBadges": [
            {
              "label": "Mode",
              "control": "Mode",
              "tone": "accent"
            },
            {
              "label": "Drive",
              "control": "Drive",
              "tone": "muted"
            },
            {
              "label": "Mix",
              "control": "Mix",
              "tone": "muted"
            }
          ],
          "gridLabels": [
            "40",
            "120",
            "500",
            "2k",
            "8k",
            "18k"
          ],
          "bands": [
            {
              "id": "cutoff-core",
              "label": "Cutoff",
              "role": "bell",
              "accent": "info",
              "xControl": "Cutoff",
              "xMin": 40,
              "xMax": 18000,
              "frequencyScale": "log",
              "yControl": "Resonance",
              "yMin": 0,
              "yMax": 100,
              "readouts": [
                "Cutoff",
                "Resonance",
                {
                  "label": "Mode",
                  "control": "Mode"
                }
              ]
            },
            {
              "id": "follow-band",
              "label": "Follow",
              "role": "bell",
              "accent": "warning",
              "x": 0.76,
              "yControl": "Envelope Follow",
              "yMin": 0.005,
              "yMax": 0.5,
              "readouts": [
                "Envelope Follow",
                "Drive",
                "Mix"
              ]
            },
            {
              "id": "mix-band",
              "label": "Mix",
              "role": "shelf",
              "accent": "accent",
              "x": 0.9,
              "yControl": "Mix",
              "yMin": 0,
              "yMax": 100,
              "readouts": [
                "Mix",
                "Output",
                "Bypass"
              ]
            }
          ]
        },
        "output-popover": {
          "title": "Output tools",
          "description": "Shared footer tools keep the compact filter lane aligned with the rest of the suite.",
          "items": [
            {
              "label": "Envelope",
              "meterId": "envelope"
            },
            {
              "label": "Envelope Follow",
              "control": "Envelope Follow"
            },
            {
              "label": "Drive",
              "control": "Drive"
            },
            {
              "label": "Mix",
              "control": "Mix"
            },
            {
              "label": "Output",
              "control": "Output"
            },
            {
              "label": "Bypass",
              "control": "Bypass"
            }
          ]
        }
      }
    },
    "statusText": "Mini filter scaffold with mode selection, cutoff and resonance shaping, envelope follow, drive, wet/dry mix, output trim, and bypass.",
    "controlOrder": [
      "Mode",
      "Cutoff",
      "Resonance",
      "Envelope Follow",
      "Drive",
      "Mix",
      "Output",
      "Bypass"
    ],
    "meters": [
      {
        "id": "inputPeak",
        "label": "Input Peak",
        "max": 78,
        "mode": "peak"
      },
      {
        "id": "envelope",
        "label": "Envelope",
        "max": 100,
        "mode": "peak"
      },
      {
        "id": "outputPeak",
        "label": "Output Peak",
        "max": 78,
        "mode": "peak"
      }
    ]
  },
  "au": {
    "type": "aufx",
    "subtype": "Pckt",
    "manufacturer": "Mlng",
    "tags": [
      "Filter",
