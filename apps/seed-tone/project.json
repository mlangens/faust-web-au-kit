{
  "name": "seed-tone",
  "version": "0.1.0",
  "owner": "mlangens",
  "companyName": "Max Langensiepen",
  "companyTag": "Mlng",
  "productName": "Seed Tone",
  "artifactStem": "SeedTone",
  "bundleId": "io.github.mlangens.faust-web-au-kit.seed-tone",
  "description": "Best-effort simple synth scaffold with a primary oscillator, cutoff/resonance shaping, color/sub/noise layers, and shared Northline family metadata.",
  "license": "MIT",
  "plugin": {
    "kind": "instrument",
    "inputs": 0,
    "outputs": 2,
    "midiInput": true,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "clap",
      "vst3",
      "auv2",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 1
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "SeedToneDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "simple-synth",
    "catalog": {
      "productId": "seed-tone",
      "prototypeRole": "parallel-wave-scaffold"
    },
    "shell": {
      "hero": {
        "status": "Seed Tone is a simple synth scaffold with a primary oscillator, filter motion, color/sub/noise layers, and shared family chrome."
      },
      "sections": {
        "controls": {
          "title": "Synth Surface",
          "description": "Seed Tone exposes a compact synth layout mapped through the shared Northline preview."
        },
        "meters": {
          "title": "Response Preview",
          "description": "Meter motion stays schematic for now, but the synth architecture and family metadata are real."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Wave": [
          "Sine",
          "Triangle",
          "Saw",
          "Pulse"
        ],
        "Motion": [
          "Still",
          "Drift",
          "Bloom",
          "Pulse"
        ]
      }
    },
    "preview": {
      "controls": {
        "layout": "sectioned",
        "sections": [
          {
            "id": "voice-modes",
            "title": "Voice Modes",
            "description": "Wave choice and motion behavior stay together so the reduced synth still reads like one intentional voice module.",
            "kind": "segmented-strip",
            "items": [
              {
                "control": "Wave"
              },
              {
                "control": "Motion"
              }
            ]
          },
          {
            "id": "voice-blend",
            "title": "Voice Blend",
            "description": "Color, sub, noise, and drive sit in a shared shaping grid instead of a flat synth utility row.",
            "kind": "dial-grid",
            "columns": 4,
            "items": [
              {
                "control": "Color",
                "surfaceOnly": true
              },
              {
                "control": "Sub",
                "surfaceOnly": true
              },
              {
                "control": "Noise",
                "surfaceOnly": true
              },
              {
                "control": "Drive",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "tone-envelope",
            "title": "Tone + Envelope",
            "description": "Filter shaping and contour timing stay grouped as one compact voice-shaping block.",
            "kind": "dial-grid",
            "columns": 4,
            "items": [
              {
                "control": "Cutoff",
                "surfaceOnly": true
              },
              {
                "control": "Resonance",
                "surfaceOnly": true
              },
              {
                "control": "Attack",
                "surfaceOnly": true
              },
              {
                "control": "Release",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "field-output",
            "title": "Field + Output",
            "description": "Stereo spread and final trim live in a narrow shared strip to keep the synth scaffold feeling tidy.",
            "kind": "fader-bank",
            "columns": 2,
            "items": [
              {
                "control": "Stereo Width",
                "surfaceOnly": true
              },
              {
                "control": "Output Trim",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "performance-input",
            "title": "Performance Input",
            "description": "Preview performance controls stay grouped instead of falling back into a generic supplemental bucket.",
            "kind": "mixed-grid",
            "columns": 2,
            "items": [
              {
                "control": "freq",
                "widget": "slider",
                "span": 2
              },
              {
                "control": "gain",
                "widget": "slider"
              },
              {
                "control": "gate",
                "widget": "toggle"
              }
            ]
          }
        ],
        "supplementalTitle": "Supplemental Seed Tone Controls",
        "supplementalDescription": "Any added synth helpers stay available here until Seed Tone gets another reduced-layout pass."
      },
      "surfaces": {
        "section-grid": {
          "title": "Voice grid",
          "description": "A shared grouped panel surface maps oscillator color, tone shaping, motion, and output without adding a synth-specific renderer.",
          "focusBadges": [
            {
              "label": "Wave",
              "control": "Wave",
              "tone": "accent"
            },
            {
              "label": "Motion",
              "control": "Motion",
              "tone": "muted"
            },
            {
              "label": "Drive",
              "control": "Drive",
              "tone": "warning"
            }
          ],
          "sections": [
            {
              "id": "oscillator",
              "label": "Oscillator",
              "accent": "info",
              "meterId": "voiceLevel",
              "items": [
                "Wave",
                "Color",
                "Sub",
                "Noise"
              ]
            },
            {
              "id": "tone",
              "label": "Tone",
              "accent": "warning",
              "summaryControl": "Cutoff",
              "activityControls": [
                "Cutoff",
                "Resonance",
                "Drive"
              ],
              "items": [
                "Cutoff",
                "Resonance",
                "Drive"
              ]
            },
            {
              "id": "motion",
              "label": "Motion",
              "accent": "positive",
              "meterId": "motionLevel",
              "items": [
                "Motion",
                "Stereo Width",
                "Attack",
                "Release"
              ]
            },
            {
              "id": "output",
              "label": "Output",
              "accent": "accent",
              "meterId": "outputPeak",
              "items": [
                "Output Trim",
                {
                  "label": "Output Peak",
                  "meterId": "outputPeak"
                }
              ]
            }
          ]
        }
      }
    },
    "statusText": "MIDI-ready simple synth scaffold with one oscillator core, cutoff/resonance shaping, contour motion, color/sub/noise layers, drive, and envelope shaping.",
    "controlOrder": [
      "Wave",
      "Cutoff",
      "Resonance",
      "Color",
      "Sub",
      "Noise",
      "Motion",
      "Drive",
      "Stereo Width",
      "Attack",
      "Release",
      "Output Trim"
    ],
    "meters": [
      {
        "id": "voiceLevel",
        "label": "Voice Level",
        "max": 78,
        "mode": "peak"
      },
      {
        "id": "motionLevel",
        "label": "Motion Level",
        "max": 78,
        "mode": "peak"
      },
      {
        "id": "outputPeak",
        "label": "Output Peak",
        "max": 78,
        "mode": "peak"
      }
    ]
  },
  "au": {
    "type": "aumu",
    "subtype": "SdTo",
    "manufacturer": "Mlng",
    "tags": [
      "Synthesizer"
    ]
  },
  "clap": {
    "id": "io.github.mlangens.faust-web-au-kit.seed-tone",
    "description": "Simple MIDI synth scaffold with shared framework-native preview metadata.",
    "features": [
      "instrument",
      "synthesizer",
      "stereo"
    ]
  },
  "vst3": {
    "categories": [
      "Instrument",
