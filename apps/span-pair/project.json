{
  "name": "span-pair",
  "version": "0.1.0",
  "owner": "mlangens",
  "companyName": "Max Langensiepen",
  "companyTag": "Mlng",
  "productName": "Span Pair",
  "artifactStem": "SpanPair",
  "bundleId": "io.github.mlangens.faust-web-au-kit.span-pair",
  "description": "Best-effort dual-filter utility scaffold with routing, linked cutoff spacing, drive, output trim, and shared Northline suite metadata.",
  "license": "MIT",
  "plugin": {
    "kind": "effect",
    "inputs": 2,
    "outputs": 2,
    "midiInput": false,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "auv2",
      "clap",
      "vst3",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 1
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "SpanPairDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "dual-filter",
    "catalog": {
      "productId": "span-pair",
      "prototypeRole": "parallel-wave-scaffold"
    },
    "shell": {
      "hero": {
        "status": "Dual-filter scaffold on the shared family manifest with neutral studio chrome and paired cutoff control."
      },
      "sections": {
        "controls": {
          "title": "Filter Surface",
          "description": "Span Pair exposes linked A/B cutoff and resonance controls with routing, spacing, drive, and mix mapped through the shared family-aware preview."
        },
        "meters": {
          "title": "Response Preview",
          "description": "Meter motion stays schematic for now, but the control surface and family metadata are real."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Mode": [
          "Series",
          "Parallel",
          "Split"
        ],
        "Routing": [
          "Stereo",
          "Cross",
          "Mono"
        ]
      }
    },
    "preview": {
      "controls": {
        "layout": "sectioned",
        "sections": [
          {
            "id": "routing-modes",
            "title": "Routing Modes",
            "description": "Mode and routing stay in a shared strip so the utility lane leads with signal flow decisions first.",
            "kind": "segmented-strip",
            "items": [
              {
                "control": "Mode"
              },
              {
                "control": "Routing"
              }
            ]
          },
          {
            "id": "filter-a-shape",
            "title": "Filter A",
            "description": "The first filter keeps cutoff and resonance together as a compact paired module.",
            "kind": "dial-grid",
            "columns": 2,
            "items": [
              {
                "control": "Filter A Cutoff",
                "surfaceOnly": true
              },
              {
                "control": "Filter A Resonance",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "filter-b-shape",
            "title": "Filter B",
            "description": "The second filter mirrors the first so both sides read as balanced shared widgets.",
            "kind": "dial-grid",
            "columns": 2,
            "items": [
              {
                "control": "Filter B Cutoff",
                "surfaceOnly": true
              },
              {
                "control": "Filter B Resonance",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "span-coupling",
            "title": "Span Coupling",
            "description": "Spacing, link depth, and drive sit in a tight strip for the compact dual-filter utility flow.",
            "kind": "fader-bank",
            "columns": 3,
            "items": [
              {
                "control": "Spacing",
                "surfaceOnly": true
              },
              {
                "control": "Link",
                "surfaceOnly": true
              },
              {
                "control": "Drive",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "mix-output",
            "title": "Mix + Output",
            "description": "Wet balance, trim, and bypass stay in their own closing bank instead of a leftover slider cluster.",
            "kind": "fader-bank",
            "columns": 3,
            "items": [
              {
                "control": "Mix",
                "surfaceOnly": true
              },
              {
                "control": "Output",
                "surfaceOnly": true
              },
              {
                "control": "Bypass"
              }
            ]
          }
        ],
