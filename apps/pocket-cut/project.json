{
  "name": "pocket-cut",
  "version": "0.1.0",
  "owner": "mlangens",
  "companyName": "Max Langensiepen",
  "companyTag": "Mlng",
  "productName": "Pocket Cut",
  "artifactStem": "PocketCut",
  "bundleId": "io.github.mlangens.faust-web-au-kit.pocket-cut",
  "description": "Mini filter utility scaffold with shared Northline family metadata, envelope-follow motion, drive, mix, and bypass.",
  "license": "MIT",
  "plugin": {
    "kind": "effect",
    "inputs": 2,
    "outputs": 2,
    "midiInput": false,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "auv2",
      "clap",
      "vst3",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 1
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "PocketCutDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "mini-filter",
    "catalog": {
      "productId": "pocket-cut",
      "prototypeRole": "parallel-wave-scaffold"
    },
    "overrides": {
      "surfacePresetIds": [
        "filter-canvas",
        "output-popover"
      ],
      "layoutProfile": "compact-surface"
    },
    "shell": {
      "hero": {
        "status": "Pocket Cut is a mini filter scaffold running on the shared family manifest with neutral studio chrome."
      },
      "sections": {
        "controls": {
          "title": "Filter Surface",
          "description": "Pocket Cut exposes a compact filter control set mapped through the shared Northline preview."
        },
        "meters": {
          "title": "Response Preview",
          "description": "Meter motion stays schematic for now, but the control surface and family metadata are real."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Mode": [
          "Low Pass",
          "Band Pass",
          "Notch",
          "High Pass"
        ]
      }
    },
    "statusText": "Mini filter scaffold with mode selection, cutoff and resonance shaping, envelope follow, drive, wet/dry mix, output trim, and bypass.",
    "controlOrder": [
      "Mode",
      "Cutoff",
      "Resonance",
      "Envelope Follow",
      "Drive",
      "Mix",
      "Output",
      "Bypass"
    ],
    "meters": [
      {
        "id": "inputPeak",
        "label": "Input Peak",
        "max": 78,
        "mode": "peak"
      },
      {
        "id": "envelope",
        "label": "Envelope",
        "max": 100,
        "mode": "peak"
      },
      {
        "id": "outputPeak",
        "label": "Output Peak",
        "max": 78,
        "mode": "peak"
      }
    ]
  },
  "au": {
    "type": "aufx",
    "subtype": "Pckt",
    "manufacturer": "Mlng",
    "tags": [
      "Filter",
      "Effects"
    ]
  },
  "clap": {
    "id": "io.github.mlangens.faust-web-au-kit.pocket-cut",
    "description": "Mini filter utility with shared family metadata, envelope-follow motion, and wet/dry control.",
