              "role": "shelf",
              "accent": "warning",
              "x": 0.18,
              "yControl": "Age",
              "yMin": 0,
              "yMax": 100,
              "readouts": [
                "Age",
                "Tone"
              ]
            },
            {
              "id": "tone-band",
              "label": "Bloom",
              "role": "bell",
              "accent": "info",
