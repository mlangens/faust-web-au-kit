        "title": "Omniplugin",
        "description": "Realtime-safe primitive slots for building different sounds in a DAW without changing the plugin parameter list.",
        "status": "Four fixed primitive slots, macro-safe automation, and an explicit path for local AI suggestions to populate the chain."
      },
      "sections": {
        "controls": {
          "title": "Primitive Slots",
          "description": "Each slot exposes type, amount, tone, and mix so DAW automation remains stable while the chain changes character."
        },
        "meters": {
          "title": "Assembly Meters",
          "description": "Input, primitive motion, guard activity, and output are exposed as the first realtime omniplugin telemetry contract."
        },
        "surfaces": {
          "title": "Chain Builder",
          "description": "The first installable pass uses fixed slots as the native bridge for future manual and Qwen-suggested assemblies."
        }
      }
