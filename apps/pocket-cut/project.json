      "auv2",
      "clap",
      "vst3",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 1
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "PocketCutDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "mini-filter",
    "catalog": {
      "productId": "pocket-cut",
      "prototypeRole": "parallel-wave-scaffold"
    },
    "overrides": {
