              ],
              "readouts": [
                "Time",
                "Offset",
                "Feedback"
              ]
            },
            {
              "id": "motion-slot",
              "label": "Motion lane",
              "assignment": "Wow + flutter",
              "amountControl": "Mod Depth",
              "activityControls": [
                "Mod Depth",
                "Flutter"
              ],
              "readouts": [
                "Mod Depth",
                "Mod Rate",
                "Flutter"
              ]
            },
            {
              "id": "bloom-slot",
              "label": "Bloom tail",
              "assignment": "Smear + age",
              "amountControl": "Smear",
              "activityControls": [
                "Smear",
                "Age"
              ],
              "readouts": [
                "Smear",
                "Age",
                "Tone"
              ]
            },
            {
              "id": "field-slot",
              "label": "Output field",
              "assignment": "Width + freeze",
              "amountControl": "Width",
              "activityControls": [
                "Width",
                "Mix"
              ],
              "readouts": [
                "Width",
                "Mix",
                "Output"
              ]
            }
          ]
        },
        "output-popover": {
          "title": "Output tools",
          "description": "Shared footer utilities handle freeze, blend, output trim, and bypass.",
          "items": [
            {
              "label": "Freeze",
              "control": "Freeze"
            },
            {
              "label": "Mix",
              "control": "Mix"
            },
            {
              "label": "Output",
              "control": "Output"
            },
            {
              "label": "Bypass",
              "control": "Bypass"
            }
          ]
        }
      }
    },
    "statusText": "Stereo modulation delay with route selection, offset timing, age and flutter shaping, diffuse bloom, freeze hold, width control, and output trim.",
    "controlOrder": [
      "Mode",
