{
  "name": "latch-line",
  "version": "0.2.0",
  "owner": "mlangens",
  "companyName": "Max Langensiepen",
  "companyTag": "Mlng",
  "productName": "Latch Line",
  "artifactStem": "LatchLine",
  "bundleId": "io.github.mlangens.faust-web-au-kit.latch-line",
  "description": "Character gate-expander with richer detector routing, closure shaping, and monitor utilities built on the shared Northline family.",
  "license": "MIT",
  "plugin": {
    "kind": "effect",
    "inputs": 2,
    "outputs": 2,
    "midiInput": false,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "auv2",
      "clap",
      "vst3",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 1
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "LatchLineDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "gate-expander",
    "catalog": {
      "productId": "latch-line",
      "prototypeRole": "fidelity-wave-latch-line"
    },
    "shell": {
      "hero": {
        "status": "Gate-expander fidelity pass with richer detector routing, closure contour, and neutral Northline studio chrome."
      },
      "sections": {
        "controls": {
          "title": "Dynamics Surface",
          "description": "Latch Line now centers on mode-shaped closure, detector voicing, stereo linking, floor control, and monitor routing."
        },
        "meters": {
          "title": "Response Preview",
          "description": "The meter contract now separates input, detector drive, closure depth, gain reduction, and output so the gate lane reads more like a finished tool."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Mode": [
          "Gate",
          "Expand",
          "Duck"
        ],
        "Style": [
          "Soft",
          "Balanced",
          "Tight",
          "Clamp"
        ],
        "Detector Mode": [
          "Peak",
          "Contour",
          "Average"
        ],
        "Detector Focus": [
          "Full",
          "Body",
          "Edge"
        ],
        "Monitor": [
          "Program",
          "Detector",
          "Difference"
        ]
      }
    },
    "preview": {
      "controls": {
        "layout": "sectioned",
        "sections": [
          {
            "id": "gate-routing",
            "title": "Gate Routing",
            "description": "Keep closure mode, detector voicing, and monitor paths together in one shared segmented strip.",
            "kind": "segmented-strip",
            "items": [
              {
                "control": "Mode"
              },
              {
                "control": "Style"
              },
              {
                "control": "Detector Mode"
              },
              {
                "control": "Detector Focus"
              },
              {
                "control": "Monitor"
              }
            ]
          },
          {
            "id": "closure-staging",
            "title": "Closure Staging",
            "description": "Use a shared fader bank for threshold, range, floor, blend, and output moves.",
            "kind": "fader-bank",
            "columns": 5,
            "items": [
              {
                "control": "Threshold",
                "surfaceOnly": true
              },
              {
                "control": "Range",
                "surfaceOnly": true
              },
              {
                "control": "Floor",
                "surfaceOnly": true
              },
              {
                "control": "Mix",
                "surfaceOnly": true
              },
              {
                "control": "Output",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "detector-response",
            "title": "Detector Response",
            "description": "Move timing, hysteresis, detector filtering, and linking into the shared dial grid.",
            "kind": "dial-grid",
            "items": [
              {
                "control": "Attack",
                "surfaceOnly": true
              },
              {
                "control": "Hold",
                "surfaceOnly": true
              },
              {
                "control": "Release",
                "surfaceOnly": true
              },
              {
                "control": "Hysteresis",
                "surfaceOnly": true
              },
              {
                "control": "Detector HP",
                "surfaceOnly": true
              },
              {
                "control": "Detector Tilt",
                "surfaceOnly": true
              },
              {
                "control": "Stereo Link",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "utility-toggles",
            "title": "Utility Toggles",
            "description": "Keep the hard bypass switch isolated in the shared toggle bank.",
            "kind": "toggle-bank",
            "columns": 1,
            "items": [
              {
                "control": "Bypass"
              }
            ]
          }
        ],
        "supplementalTitle": "Additional Controls",
        "supplementalDescription": "Any gate parameters not yet mapped into the grouped layout stay available here while the preview evolves."
      },
      "surfaces": {
        "transfer-curve": {
          "title": "Closure response",
          "description": "The shared gate curve now visualizes threshold, closure range, floor behavior, and timing without splitting into a product-specific panel.",
          "focusBadges": [
            {
              "label": "Mode",
              "control": "Mode",
              "tone": "accent"
            },
            {
              "label": "Style",
              "control": "Style",
              "tone": "muted"
            },
            {
              "label": "Detector",
              "control": "Detector Mode",
              "tone": "muted"
            }
          ],
          "curveControls": [
            {
              "role": "input",
              "label": "Threshold",
              "control": "Threshold",
              "tone": "warning"
            },
            {
              "role": "drive",
              "label": "Range",
              "control": "Range",
              "tone": "accent"
            },
            {
              "role": "ceiling",
              "label": "Floor",
              "control": "Floor",
              "tone": "positive"
            }
          ],
          "timingItems": [
            {
              "label": "Attack",
              "control": "Attack"
            },
            {
              "label": "Hold",
              "control": "Hold"
            },
            {
              "label": "Release",
              "control": "Release"
            },
            {
              "label": "Hysteresis",
              "control": "Hysteresis"
            }
          ],
          "detailItems": [
            {
              "label": "Stereo Link",
              "control": "Stereo Link"
            },
            {
              "label": "Detector Focus",
              "control": "Detector Focus"
            }
          ],
          "monitor": {
            "label": "Monitor",
            "control": "Monitor"
          },
          "meters": [
            {
              "label": "Closure Depth",
              "meter": "closureDepth"
            },
            {
              "label": "Gain Reduction",
              "meter": "gainReduction"
            },
            {
              "label": "Detector Drive",
              "meter": "detectorDrive"
            }
          ]
        },
        "sidechain-editor": {
          "title": "Detector shape",
          "description": "The shared detector editor covers high-pass, focus, and tilt shaping while staying aligned with the rest of the dynamics lane.",
          "selection": "detector-focus-band",
          "focusBadges": [
            {
              "label": "Focus",
              "control": "Detector Focus",
              "tone": "accent"
            },
            {
              "label": "Detector",
              "control": "Detector Mode",
              "tone": "muted"
            },
            {
              "label": "Monitor",
              "control": "Monitor",
              "tone": "muted"
            }
          ],
          "gridLabels": [
            "20",
            "50",
            "100",
            "200",
            "500",
            "1k",
            "2k",
            "5k",
            "10k",
            "20k"
          ],
          "bands": [
            {
              "id": "detector-hp-band",
              "label": "HP",
              "role": "cut",
              "accent": "warning",
              "xControl": "Detector HP",
              "xMin": 20,
              "xMax": 4000,
              "y": 0.18,
              "readouts": [
                {
                  "label": "Detector HP",
                  "control": "Detector HP"
                },
                {
                  "label": "Detector Mode",
                  "control": "Detector Mode"
                }
              ]
            },
            {
              "id": "detector-focus-band",
              "label": "Focus",
              "role": "bell",
              "accent": "info",
              "x": 0.54,
              "yControl": "Detector Focus",
              "yMin": 0,
              "yMax": 2,
              "readouts": [
                {
                  "label": "Detector Focus",
                  "control": "Detector Focus"
                },
                {
                  "label": "Hysteresis",
                  "control": "Hysteresis"
                }
              ]
            },
            {
              "id": "detector-tilt-band",
              "label": "Tilt",
              "role": "shelf",
              "accent": "positive",
              "x": 0.84,
              "yControl": "Detector Tilt",
              "yMin": -100,
              "yMax": 100,
              "readouts": [
                {
                  "label": "Detector Tilt",
                  "control": "Detector Tilt"
                },
                {
                  "label": "Monitor",
                  "control": "Monitor"
                }
              ]
            }
          ]
        },
        "output-popover": {
          "title": "Output tools",
          "description": "Footer utilities stay shared across the dynamics lane for blend, output trim, monitor routing, and bypass.",
          "items": [
            {
              "label": "Mix",
              "control": "Mix"
            },
            {
              "label": "Output",
              "control": "Output"
            },
            {
              "label": "Monitor",
              "control": "Monitor"
            },
            {
              "label": "Bypass",
              "control": "Bypass"
            }
          ]
        }
      }
    },
    "statusText": "Character gate-expander with mode-shaped closure, selectable detector behavior, hysteresis and floor control, stereo linking, parallel mix, and monitor utilities.",
    "controlOrder": [
      "Mode",
      "Style",
      "Detector Mode",
      "Threshold",
      "Range",
      "Floor",
      "Attack",
      "Hold",
      "Release",
      "Hysteresis",
      "Stereo Link",
      "Detector HP",
      "Detector Tilt",
      "Detector Focus",
      "Mix",
      "Output",
      "Monitor",
      "Bypass"
    ],
    "meters": [
      {
        "id": "inputPeak",
        "label": "Input Peak",
        "max": 78,
        "mode": "peak",
        "style": "thin-trough",
        "ballistics": "fast-rise-medium-fall"
      },
      {
        "id": "detectorDrive",
        "label": "Detector Drive",
        "max": 78,
        "mode": "peak",
        "style": "thin-trough",
        "ballistics": "fast-rise-medium-fall"
      },
      {
        "id": "closureDepth",
        "label": "Closure Depth",
        "max": 100,
        "mode": "depth",
        "unit": "%",
        "style": "thin-trough",
        "ballistics": "fast-rise-medium-fall"
      },
      {
        "id": "gainReduction",
        "label": "Gain Reduction",
        "max": 60,
        "mode": "gr"
      },
      {
        "id": "outputPeak",
        "label": "Output Peak",
        "max": 78,
        "mode": "peak",
        "style": "thin-trough",
        "ballistics": "fast-rise-medium-fall"
      }
    ]
  },
  "au": {
    "type": "aufx",
    "subtype": "LtLn",
    "manufacturer": "Mlng",
    "tags": [
      "Dynamics",
      "Effects"
    ]
  },
  "clap": {
    "id": "io.github.mlangens.faust-web-au-kit.latch-line",
