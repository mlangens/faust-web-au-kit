{
  "name": "pulse-pad",
  "version": "0.3.1",
  "owner": "mlangens",
  "companyName": "Max Langensiepen",
  "companyTag": "Mlng",
  "productName": "Pulse Pad",
  "artifactStem": "PulsePad",
  "bundleId": "io.github.mlangens.faust-web-au-kit.pulse-pad",
  "description": "Polyphonic Faust synth with morphable tone shaping, stereo motion, and shared analyzer telemetry.",
  "license": "MIT",
  "plugin": {
    "kind": "instrument",
    "inputs": 0,
    "outputs": 2,
    "midiInput": true,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "clap",
      "vst3",
      "auv2",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 1
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "PulsePadDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "modular-synth",
    "catalog": {
      "productId": "pulse-pad",
      "prototypeRole": "suite-polish-pass"
    },
    "shell": {
      "hero": {
        "status": "Compact morph synth with texture-led oscillator color, contour sweep, stereo motion, and drive-aware output in the shared Northline instrument shell."
      },
      "sections": {
        "controls": {
          "title": "Morph Surface",
          "description": "Pulse Pad now uses the full shared synth lane: voice stack, tone field, module rack, motion dock, and performance strip without reverting to app-specific preview code."
        },
        "meters": {
          "title": "Voice Preview",
          "description": "The meter contract keeps body, motion bloom, and output peak separated so the smaller synth still reads like a finished instrument."
        }
      }
    },
    "display": {
      "controls": {
        "gate": {
          "onLabel": "Held",
          "offLabel": "Idle"
        }
      }
    },
    "preview": {
      "controls": {
        "layout": "sectioned",
        "sections": [
          {
            "id": "voice-shape",
            "title": "Voice Shape",
            "description": "Shared dials keep the core oscillator color controls together before motion and staging take over.",
            "kind": "dial-grid",
            "columns": 4,
            "items": [
              {
                "control": "Texture",
                "widget": "dial"
              },
              {
                "control": "Tone",
                "widget": "dial"
              },
              {
                "control": "Detune",
                "widget": "dial"
              },
              {
                "control": "Sub",
                "widget": "dial"
              }
            ]
          },
          {
            "id": "motion-envelope",
            "title": "Contour and Motion",
            "description": "Contour sweep, stereo movement, and envelope timing now read as one reusable motion cluster.",
            "kind": "dial-grid",
            "columns": 4,
            "items": [
              {
                "control": "Contour",
                "widget": "dial"
              },
              {
                "control": "Motion",
                "widget": "dial"
              },
              {
                "control": "Attack",
                "widget": "dial"
              },
              {
                "control": "Release",
                "widget": "dial"
              }
            ]
          },
        {
          "id": "stage-field",
          "title": "Stage and Field",
          "description": "Drive and width move into a compact shared staging group instead of sitting in a flat slider row.",
          "kind": "mixed-grid",
          "columns": 2,
          "items": [
            {
              "control": "Drive",
              "widget": "fader"
            },
            {
              "control": "Stereo Width",
              "widget": "slider"
            }
          ]
        },
        {
          "id": "performance-readout",
          "title": "Performance Readout",
          "description": "Keep the lightweight preview transport controls grouped instead of leaving hidden synth plumbing to the fallback panel.",
          "kind": "mixed-grid",
          "columns": 3,
          "items": [
            {
              "control": "freq",
              "widget": "dial"
            },
            {
              "control": "gain",
              "widget": "fader"
            },
            {
              "control": "gate",
              "widget": "toggle"
            }
          ]
        }
      ],
        "supplementalTitle": "Performance Readout",
        "supplementalDescription": "Pulse Pad's preview controls now favor grouped shared widgets for voice shape, motion contour, and output field."
      },
      "surfaces": {
        "oscillator-stack": {
          "title": "Voice stack",
          "description": "Shared module cards frame Pulse Pad's lean oscillator, tone sweep, and stereo movement as a first-class suite instrument.",
          "focusBadges": [
            {
              "label": "Texture",
              "control": "Texture",
              "tone": "accent"
            },
            {
              "label": "Motion",
              "control": "Motion",
              "tone": "muted"
            },
            {
              "label": "Drive",
              "control": "Drive",
              "tone": "warning"
            }
          ],
          "modules": [
            {
