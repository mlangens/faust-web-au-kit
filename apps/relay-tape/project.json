{
  "name": "relay-tape",
  "version": "0.2.0",
  "owner": "mlangens",
  "companyName": "Max Langensiepen",
  "companyTag": "Mlng",
  "productName": "Relay Tape",
  "artifactStem": "RelayTape",
  "bundleId": "io.github.mlangens.faust-web-au-kit.relay-tape",
  "description": "Stereo modulation delay with deeper routing, offset timing, age and flutter shaping, diffusion bloom, freeze hold, and a richer preview-oriented meter contract.",
  "license": "MIT",
  "plugin": {
    "kind": "effect",
    "inputs": 2,
    "outputs": 2,
    "midiInput": false,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "auv2",
      "clap",
      "vst3",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 1
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "RelayTapeDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "mod-delay",
    "catalog": {
      "productId": "relay-tape",
      "prototypeRole": "fidelity-wave-pass-1"
    },
    "overrides": {
      "surfacePresetIds": [
        "delay-timeline",
        "filter-canvas",
        "modulation-dock",
        "output-popover"
      ],
      "layoutProfile": "timeline-plus-dock"
    },
    "shell": {
      "hero": {
        "status": "Stereo modulation delay surface with offset timing, age and flutter motion, diffuse bloom, width shaping, and freeze-aware hold behavior."
      },
      "sections": {
        "controls": {
          "title": "Delay Surface",
          "description": "Relay Tape now exposes a richer reusable delay vocabulary with bounce or crossfeed routing, stereo offset, age shaping, modulation drift, bloom diffusion, and output width control."
        },
        "meters": {
          "title": "Motion Preview",
          "description": "The meter contract now separates input drive, modulation activity, diffuse tail energy, stereo spread, freeze hold, and output level for a more informative shared-suite preview."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Mode": [
          "Clear",
          "Worn",
          "Bloom"
        ],
        "Routing": [
          "Stereo",
          "Bounce",
          "Mono Sum",
          "Crossfeed"
        ]
      }
    },
    "preview": {
      "surfaces": {
        "delay-timeline": {
          "title": "Delay timeline",
          "description": "The shared timeline surface now stages entry, offset echoes, bloom, and freeze hold in one reusable motion lane.",
          "selection": "main-echo",
          "focusBadges": [
            {
              "label": "Mode",
              "control": "Mode",
              "tone": "accent"
            },
            {
              "label": "Routing",
              "control": "Routing",
              "tone": "muted"
            },
            {
              "label": "Freeze",
              "control": "Freeze",
              "tone": "muted"
            }
          ],
          "lanes": [
            "Input",
            "Echo",
            "Tail"
          ],
          "taps": [
            {
              "id": "input-send",
              "label": "Input",
              "lane": 0,
              "x": 0.08,
              "meterId": "inputPeak",
              "readouts": [
                {
                  "label": "Mode",
                  "control": "Mode"
                },
                {
                  "label": "Routing",
                  "control": "Routing"
                }
              ]
            },
            {
              "id": "main-echo",
              "label": "Main",
              "lane": 1,
              "timeControl": "Time",
              "xMin": 80,
              "xMax": 1200,
              "meterId": "echoDrive",
              "readouts": [
                "Time",
                "Feedback",
                "Mod Depth"
              ]
            },
            {
              "id": "offset-echo",
              "label": "Offset",
              "lane": 1,
              "timeControl": "Offset",
              "xMin": 0,
              "xMax": 100,
              "meterId": "motion",
              "readouts": [
                "Offset",
                "Mod Rate",
                "Flutter"
              ]
            },
            {
              "id": "bloom-tail",
              "label": "Bloom",
              "lane": 2,
              "x": 0.82,
              "meterId": "diffuseTail",
              "readouts": [
                "Smear",
                "Tone",
                "Age"
              ]
            },
            {
              "id": "freeze-hold",
              "label": "Hold",
              "lane": 2,
              "x": 0.92,
              "meterId": "freezeHold",
              "readouts": [
                "Freeze",
                "Width",
                "Mix"
              ]
            }
          ],
          "connections": [
            {
              "from": "input-send",
              "to": "main-echo",
              "tone": "warning"
            },
            {
              "from": "main-echo",
              "to": "offset-echo",
              "tone": "info"
            },
            {
              "from": "offset-echo",
              "to": "bloom-tail",
              "tone": "accent"
            },
            {
              "from": "bloom-tail",
              "to": "freeze-hold",
              "tone": "positive"
            }
          ]
        },
