              "accent": "accent",
              "xControl": "Mod Rate",
              "xMin": 0.05,
              "xMax": 4,
              "frequencyScale": "log",
              "yControl": "Flutter",
              "yMin": 0,
              "yMax": 100,
              "qControl": "Mod Depth",
              "qMax": 100,
              "readouts": [
                "Mod Rate",
                "Mod Depth",
                "Flutter"
              ]
            },
            {
              "id": "width-band",
              "label": "Field",
              "role": "shelf",
              "accent": "positive",
              "x": 0.88,
              "yControl": "Width",
              "yMin": 0,
              "yMax": 100,
              "readouts": [
                "Width",
                "Routing"
              ]
            }
          ]
        },
        "modulation-dock": {
          "title": "Motion dock",
          "description": "A shared creative dock keeps wow, flutter, routing, and freeze behavior visible as reusable delay macros.",
          "focusBadges": [
            {
              "label": "Mode",
              "control": "Mode",
              "tone": "accent"
            },
            {
              "label": "Routing",
              "control": "Routing",
              "tone": "muted"
            },
            {
              "label": "Freeze",
              "control": "Freeze",
              "tone": "muted"
            }
