                },
                {
                  "row": "mono",
                  "column": "motion"
                },
                {
                  "row": "mono",
                  "column": "output"
                }
              ],
              "readouts": [
                "Routing",
                "Mix",
                "Output Trim"
              ]
            }
          ]
        },
        "modulation-dock": {
          "title": "Motion dock",
          "description": "The shared modulation dock keeps envelope, LFO, and bias controls visible next to the filter and routing surfaces.",
          "focusBadges": [
            {
              "label": "Motion Source",
              "control": "Motion Source",
              "tone": "accent"
            },
            {
              "label": "Style",
              "control": "Style",
              "tone": "muted"
            },
            {
              "label": "Routing",
