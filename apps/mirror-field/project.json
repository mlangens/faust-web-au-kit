  "productName": "Mirror Field",
  "artifactStem": "MirrorField",
  "bundleId": "io.github.mlangens.faust-web-au-kit.mirror-field",
  "description": "Modular synth with richer voice modes, filter voicing, motion behavior, and a denser Northline instrument surface.",
  "license": "MIT",
  "plugin": {
    "kind": "instrument",
    "inputs": 0,
    "outputs": 2,
    "midiInput": true,
    "latencySeconds": 0.0,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "auv2",
      "clap",
      "vst3",
      "standalone"
    ],
    "active": []
  },
  "oversampling": {
    "factor": 1
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "MirrorFieldDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "modular-synth",
    "catalog": {
      "productId": "mirror-field",
      "prototypeRole": "creative-fidelity-pass"
    },
    "shell": {
      "hero": {
        "status": "Modular synth fidelity pass with richer voice behavior, filter voicing, motion states, and neutral Northline studio chrome."
      },
      "sections": {
        "controls": {
          "title": "Synth Surface",
          "description": "Mirror Field now uses a fuller reusable synth vocabulary: voice mode, waveform blend, filter voicing, motion states, drift, and stereo behavior."
        },
        "meters": {
          "title": "Voice Preview",
          "description": "The meter contract now separates voice body, filter bloom, stereo spread, and output so the instrument preview reads more intentionally."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Voice Mode": [
          "Mono",
          "Duo",
          "Wide",
          "Stack"
        ],
        "Blend": [
          "Sine",
          "Triangle",
          "Saw",
          "Square"
        ],
        "Filter Mode": [
          "Soft",
          "Focus",
          "Glass"
        ],
        "Motion": [
          "Still",
          "Wander",
          "Pulse",
          "Orbit"
        ]
      }
    },
    "preview": {
      "controls": {
        "layout": "sectioned",
        "sections": [
          {
            "id": "voice-strip",
            "title": "Voice Modes",
            "description": "Shared segments keep voice, blend, filter voicing, and motion state aligned before the deeper shaping widgets appear.",
            "kind": "segmented-strip",
            "items": [
              {
                "control": "Voice Mode",
                "widget": "segment"
              },
              {
                "control": "Blend",
                "widget": "segment"
              },
              {
                "control": "Filter Mode",
                "widget": "segment"
              },
              {
                "control": "Motion",
                "widget": "segment"
              }
            ]
          },
          {
            "id": "voice-tone",
            "title": "Voice Tone",
            "description": "Shape, tone, contour, and detune now share a reusable dial grid instead of reading like a flat synth strip.",
            "kind": "dial-grid",
            "columns": 4,
            "items": [
              {
                "control": "Shape",
                "widget": "dial",
                "surfaceOnly": true
              },
              {
                "control": "Tone",
                "widget": "dial",
                "surfaceOnly": true
              },
              {
                "control": "Contour",
                "widget": "dial",
                "surfaceOnly": true
              },
              {
                "control": "Detune",
                "widget": "dial",
                "surfaceOnly": true
              }
            ]
          },
          {
            "id": "motion-envelope",
            "title": "Motion and Envelope",
            "description": "Depth, drift, and envelope timing now live in a shared motion grid.",
            "kind": "dial-grid",
            "columns": 4,
            "items": [
              {
                "control": "Mod Amount",
                "widget": "dial",
                "surfaceOnly": true
              },
              {
                "control": "Drift",
                "widget": "dial",
                "surfaceOnly": true
              },
              {
                "control": "Attack",
                "widget": "dial",
                "surfaceOnly": true
              },
              {
                "control": "Release",
                "widget": "dial",
                "surfaceOnly": true
              }
            ]
          },
        {
          "id": "stage-field",
          "title": "Stage and Field",
          "description": "Sub weight, drive, and stereo width move into a compact shared staging group.",
          "kind": "mixed-grid",
            "columns": 3,
            "items": [
              {
                "control": "Sub",
                "widget": "slider",
                "surfaceOnly": true
              },
              {
                "control": "Drive",
                "widget": "fader",
                "surfaceOnly": true
              },
            {
              "control": "Stereo Width",
              "widget": "slider",
              "surfaceOnly": true
            }
          ]
        },
        {
          "id": "performance-readout",
          "title": "Performance Readout",
          "description": "Keep the lightweight performance-preview controls grouped instead of leaving synth runtime plumbing to the fallback panel.",
