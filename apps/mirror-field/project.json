            "Tone": 0.24,
            "Contour": 0.18,
            "Drive": 0
          }
        },
        {
          "id": "feature",
          "parameters": {
            "Tone": 0.82,
            "Contour": 0.76,
            "Drive": 4,
            "Stereo Width": 72
          }
        }
      ],
      "assertions": [
