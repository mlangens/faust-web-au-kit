{
  "name": "faust-web-au-kit",
  "version": "0.3.0",
  "private": false,
  "description": "A monorepo-native Faust plugin suite framework with shared native, preview, export, and packaging tooling.",
  "type": "module",
  "scripts": {
    "export": "node ./tools/export-targets.mjs",
    "export:all": "node ./tools/export-workspace.mjs",
    "export:atlas-curve": "node ./tools/export-targets.mjs --app atlas-curve",
    "export:room-bloom": "node ./tools/export-targets.mjs --app room-bloom",
    "export:ember-drive": "node ./tools/export-targets.mjs --app ember-drive",
    "export:relay-tape": "node ./tools/export-targets.mjs --app relay-tape",
    "export:contour-forge": "node ./tools/export-targets.mjs --app contour-forge",
    "export:mirror-field": "node ./tools/export-targets.mjs --app mirror-field",
    "export:seed-tone": "node ./tools/export-targets.mjs --app seed-tone",
    "export:span-pair": "node ./tools/export-targets.mjs --app span-pair",
    "export:pocket-cut": "node ./tools/export-targets.mjs --app pocket-cut",
    "export:headroom": "node ./tools/export-targets.mjs --app headroom",
    "export:latch-line": "node ./tools/export-targets.mjs --app latch-line",
    "export:pulse-pad": "node ./tools/export-targets.mjs --app pulse-pad",
    "export:press-deck": "node ./tools/export-targets.mjs --app press-deck",
    "export:silk-guard": "node ./tools/export-targets.mjs --app silk-guard",
    "export:split-stack": "node ./tools/export-targets.mjs --app split-stack",
    "benchmark": "node ./tools/run-benchmarks.mjs",
    "benchmark:atlas-curve": "node ./tools/run-benchmarks.mjs --app atlas-curve",
    "benchmark:room-bloom": "node ./tools/run-benchmarks.mjs --app room-bloom",
    "benchmark:ember-drive": "node ./tools/run-benchmarks.mjs --app ember-drive",
    "benchmark:relay-tape": "node ./tools/run-benchmarks.mjs --app relay-tape",
    "benchmark:contour-forge": "node ./tools/run-benchmarks.mjs --app contour-forge",
    "benchmark:mirror-field": "node ./tools/run-benchmarks.mjs --app mirror-field",
    "benchmark:seed-tone": "node ./tools/run-benchmarks.mjs --app seed-tone",
    "benchmark:span-pair": "node ./tools/run-benchmarks.mjs --app span-pair",
    "benchmark:pocket-cut": "node ./tools/run-benchmarks.mjs --app pocket-cut",
    "benchmark:headroom": "node ./tools/run-benchmarks.mjs --app headroom",
    "benchmark:latch-line": "node ./tools/run-benchmarks.mjs --app latch-line",
    "benchmark:pulse-pad": "node ./tools/run-benchmarks.mjs --app pulse-pad",
    "benchmark:press-deck": "node ./tools/run-benchmarks.mjs --app press-deck",
    "benchmark:silk-guard": "node ./tools/run-benchmarks.mjs --app silk-guard",
    "benchmark:split-stack": "node ./tools/run-benchmarks.mjs --app split-stack",
    "preview": "node ./tools/preview-server.mjs",
    "build:au": "./scripts/build-au.sh",
    "build:native": "./scripts/build-native.sh",
    "doctor:au": "./scripts/doctor-au.sh",
    "install:local": "./scripts/install-local.sh",
    "package:installer": "./scripts/package-installer.sh",
    "validate:au": "./scripts/validate-au.sh",
    "test:prepare": "node ./tools/prepare-test-artifacts.mjs",
    "test:unit:run": "node --test tests/unit/**/*.test.mjs",
    "test:unit": "npm run test:unit:run",
    "test:contracts:run": "node --test tests/contracts/**/*.test.mjs",
    "test:contracts": "npm run test:prepare && npm run test:contracts:run",
    "test:integration:run": "node --test tests/integration/**/*.test.mjs",
    "test:integration": "npm run test:prepare && npm run test:integration:run",
    "test:preview:run": "playwright test",
    "test:preview": "npm run test:prepare && npm run test:preview:run",
    "test:native": "node ./tools/run-native-validation.mjs",
    "test": "npm run test:prepare && npm run test:unit:run && npm run test:contracts:run && npm run test:integration:run && npm run test:preview:run"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
