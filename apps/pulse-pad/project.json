              "meterId": "motionBloom",
              "readouts": [
                "Motion",
                "Stereo Width",
                "Release"
              ]
            }
          ]
        },
        "filter-canvas": {
          "title": "Tone field",
          "description": "The shared graph canvas becomes a compact tone map for texture, tone contour, motion, and stereo field.",
          "selection": "tone-band",
          "focusBadges": [
            {
              "label": "Texture",
              "control": "Texture",
              "tone": "accent"
            },
            {
              "label": "Contour",
              "control": "Contour",
              "tone": "muted"
            },
            {
              "label": "Motion",
              "control": "Motion",
              "tone": "muted"
