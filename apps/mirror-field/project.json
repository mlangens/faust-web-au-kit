    "shell": {
      "hero": {
        "status": "Modular synth fidelity pass with richer voice behavior, filter voicing, motion states, and neutral Northline studio chrome."
      },
      "sections": {
        "controls": {
          "title": "Synth Surface",
          "description": "Mirror Field now uses a fuller reusable synth vocabulary: voice mode, waveform blend, filter voicing, motion states, drift, and stereo behavior."
        },
        "meters": {
          "title": "Voice Preview",
          "description": "The meter contract now separates voice body, filter bloom, stereo spread, and output so the instrument preview reads more intentionally."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Voice Mode": [
          "Mono",
          "Duo",
          "Wide",
          "Stack"
