{
  "name": "limiter-lab",
  "version": "0.3.0",
  "owner": "mlangens",
  "companyName": "Max Langensiepen",
  "companyTag": "Mlng",
  "productName": "Limiter Lab",
  "artifactStem": "LimiterLab",
  "bundleId": "io.github.mlangens.faust-web-au-kit.limiter-lab",
  "description": "Native-target Faust framework proof of concept with an oversampled limiter.",
  "license": "MIT",
  "plugin": {
    "kind": "effect",
    "inputs": 2,
    "outputs": 2,
    "midiInput": false,
    "latencySeconds": 0.0015,
    "gui": {
      "native": true,
      "webPreview": true,
      "resizable": true
    }
  },
  "targets": {
    "native": [
      "auv2",
      "clap",
      "vst3",
      "standalone"
    ],
    "active": [
      "auv2"
    ]
  },
  "oversampling": {
    "factor": 4
  },
  "faust": {
    "source": "./dsp/main.dsp",
    "className": "LimiterLabDSP"
  },
  "ui": {
    "family": "northline-core",
    "familyVersion": 1,
    "variant": "mastering-limiter",
    "catalog": {
      "productId": "headroom",
      "prototypeRole": "current-app"
    },
    "overrides": {
      "surfacePresetIds": [
        "history-trace",
        "transfer-curve",
        "meter-stack",
        "output-popover"
      ],
      "layoutProfile": "slider-plus-meter-column"
    },
    "shell": {
      "hero": {
        "status": "Mastering limiter refresh with shared transfer, drive-routing splits, vintage voicing, and neutral Northline studio chrome."
      },
      "sections": {
        "controls": {
          "title": "Limiter Surface",
          "description": "Limiter Lab now centers on input and ceiling shaping, harmonic color, split drive routing, timing response, and matched output utilities."
        },
        "meters": {
          "title": "Response Preview",
          "description": "The shared limiter scaffold now tracks input, harmonic bias, clamp depth, and output recovery so the original framework example reads more intentionally."
        }
      }
    },
    "display": {
      "enumLabels": {
        "Drive Target": [
          "Both",
          "Mid",
          "Side"
        ],
        "Drive Focus": [
          "Full",
          "Low",
          "Mid",
          "High"
        ]
      },
      "controls": {
        "Vintage Response": {
          "onLabel": "Vintage",
          "offLabel": "Modern"
        }
      }
    },
    "preview": {
      "controls": {
        "layout": "sectioned",
        "sections": [
          {
            "id": "drive-routing",
            "title": "Drive Routing",
            "description": "Group the shared mode selectors so mid-side drive choices stay out of the limiter staging lane.",
            "kind": "segmented-strip",
            "items": [
              {
                "control": "Drive Target"
              },
              {
                "control": "Drive Focus"
              }
            ]
          },
          {
            "id": "limit-staging",
            "title": "Limit Staging",
            "description": "Use a shared fader bank for input gain, saturation split points, ceiling, and output trim.",
            "kind": "fader-bank",
            "items": [
              {
                "control": "Input Gain"
              },
              {
                "control": "Tube Drive"
              },
              {
                "control": "Drive Low Split"
              },
              {
                "control": "Drive High Split"
              },
              {
                "control": "Ceiling"
              },
              {
                "control": "Output Trim"
              }
            ]
          },
          {
            "id": "response-color",
            "title": "Response & Color",
            "description": "Move timing and transformer shaping into the shared dial grid instead of another flat slider run.",
            "kind": "dial-grid",
            "columns": 4,
            "items": [
              {
                "control": "Transformer Tone"
              },
              {
                "control": "Attack"
              },
              {
                "control": "Hold"
              },
              {
                "control": "Release"
              }
            ]
          },
          {
            "id": "utility-toggles",
            "title": "Utility Toggles",
            "description": "Keep voicing and bypass switches grouped into a compact shared toggle bank.",
            "kind": "toggle-bank",
            "items": [
              {
                "control": "Vintage Response"
              },
              {
                "control": "Bypass"
              }
            ]
          }
        ],
        "supplementalTitle": "Additional Controls",
        "supplementalDescription": "Any limiter parameters not yet mapped into the grouped layout stay available here while the preview evolves."
      },
      "surfaces": {
        "history-trace": {
          "title": "Drive history",
          "description": "Shared limiter traces now span input, harmonic color, routing emphasis, clamp depth, and recovered output.",
          "focusBadges": [
            {
              "label": "Target",
              "control": "Drive Target",
              "tone": "accent"
            },
            {
              "label": "Focus",
              "control": "Drive Focus",
              "tone": "muted"
            },
            {
              "label": "Vintage",
              "control": "Vintage Response",
              "tone": "muted"
            }
          ],
          "series": [
            {
              "id": "input",
              "label": "Input",
              "meterId": "inputPeak",
              "tone": "warning"
            },
            {
              "id": "color",
              "label": "Color",
              "control": "Tube Drive",
              "controls": [
                "Tube Drive",
                "Transformer Tone"
              ],
              "tone": "accent"
            },
            {
              "id": "routing",
              "label": "Routing",
              "control": "Drive Target",
              "controls": [
                "Drive Target",
                "Drive Focus"
              ],
              "tone": "info"
            },
            {
              "id": "clamp",
              "label": "Clamp",
              "meterId": "gainReduction",
              "tone": "info",
              "variant": "gr"
            },
            {
              "id": "output",
              "label": "Output",
              "meterId": "outputPeak",
              "tone": "positive"
            }
          ]
        },
        "transfer-curve": {
          "title": "Vintage clamp",
          "description": "The shared transfer view reframes Limiter Lab around input staging, tube drive, output ceiling, release timing, and vintage bite.",
          "focusBadges": [
            {
              "label": "Target",
              "control": "Drive Target",
              "tone": "accent"
            },
            {
              "label": "Focus",
              "control": "Drive Focus",
              "tone": "muted"
            },
            {
              "label": "Vintage",
              "control": "Vintage Response",
              "tone": "muted"
            }
          ],
          "curveControls": [
            {
              "role": "input",
              "label": "Input",
              "control": "Input Gain",
              "tone": "warning"
            },
            {
              "role": "drive",
              "label": "Tube Drive",
              "control": "Tube Drive",
              "tone": "accent"
            },
            {
              "role": "ceiling",
              "label": "Ceiling",
              "control": "Ceiling",
              "tone": "positive"
            }
          ],
          "timingItems": [
            {
              "label": "Attack",
              "control": "Attack"
            },
            {
              "label": "Hold",
              "control": "Hold"
            },
            {
              "label": "Release",
              "control": "Release"
            }
          ],
          "detailItems": [
            {
              "label": "Transformer Tone",
              "control": "Transformer Tone"
            },
            {
              "label": "Drive Target",
              "control": "Drive Target"
            },
            {
              "label": "Drive Focus",
              "control": "Drive Focus"
            }
          ],
          "monitor": {
            "label": "Vintage",
            "control": "Vintage Response"
          },
          "meters": [
            {
              "label": "Gain Reduction",
              "meter": "gainReduction"
            },
            {
              "label": "Input Peak",
              "meter": "inputPeak"
            },
            {
              "label": "Output Peak",
              "meter": "outputPeak"
            }
          ]
        },
        "output-popover": {
          "title": "Output tools",
          "description": "Shared footer utilities keep trim, split points, response mode, and bypass on the same reusable mastering lane.",
          "items": [
            {
              "label": "Output Trim",
              "control": "Output Trim"
            },
            {
              "label": "Drive Low Split",
              "control": "Drive Low Split"
            },
            {
              "label": "Drive High Split",
              "control": "Drive High Split"
            },
            {
              "label": "Vintage Response",
              "control": "Vintage Response"
            },
            {
              "label": "Bypass",
              "control": "Bypass"
            }
          ]
        }
      }
    },
    "statusText": "4x oversampled native runtime with shared schema for AppKit and web preview.",
    "controlOrder": [
      "Input Gain",
      "Ceiling",
      "Tube Drive",
      "Transformer Tone",
      "Drive Target",
      "Drive Focus",
      "Drive Low Split",
      "Drive High Split",
      "Attack",
      "Hold",
      "Release",
      "Output Trim",
      "Vintage Response",
      "Bypass"
    ],
    "meters": [
      {
        "id": "inputPeak",
        "label": "Input Peak",
        "max": 78,
        "mode": "peak"
      },
      {
        "id": "outputPeak",
        "label": "Output Peak",
        "max": 78,
        "mode": "peak"
      },
      {
        "id": "gainReduction",
        "label": "Gain Reduction",
        "max": 24,
        "mode": "gr"
      }
    ]
  },
  "au": {
    "type": "aufx",
    "subtype": "Lmlt",
    "manufacturer": "Mlng",
    "tags": [
      "Dynamics",
      "Effects"
    ]
  },
  "clap": {
    "id": "io.github.mlangens.faust-web-au-kit.limiter-lab",
    "description": "Oversampled limiter with tube and transformer coloration plus modern or vintage response shaping.",
    "features": [
      "audio-effect",
      "limiter",
      "mastering",
      "stereo"
    ]
  },
  "vst3": {
    "categories": [
      "Fx",
      "Dynamics",
      "Stereo"
    ],
    "componentTuid": [
      "Mlng",
      "Comp",
      "Lmlt",
      0
    ],
    "controllerTuid": [
      "Mlng",
      "Edit",
      "Lmlt",
      0
    ]
  },
  "standalone": {
    "bundleId": "io.github.mlangens.faust-web-au-kit.limiter-lab.app"
  },
  "benchmark": {
    "sampleRate": 48000,
    "blockSize": 256,
    "seconds": 6,
    "initialControls": [
      {
        "label": "Vintage Response",
        "value": 1
      },
      {
        "label": "Tube Drive",
        "value": 30
      },
      {
        "label": "Transformer Tone",
        "value": 35
      }
    ],
    "nativeTargets": [
      "c",
      "cpp",
      "wasm"
    ],
    "exportOnlyTargets": [
      "cmajor",
      "rust"
    ]
  }
}
